# LLM Configuration
# Provider: "groq" (free, default) or "gemini"
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
MODEL_NAME=llama-3.3-70b-versatile

# Gemini (alternative provider)
GOOGLE_API_KEY=your-gemini-api-key-here

# OpenEMR REST API Connection
OPENEMR_BASE_URL=https://localhost:9300
OPENEMR_USER=admin
OPENEMR_PASS=pass
OPENEMR_ENABLED=true

# LangSmith Observability (enable for full trace logging)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=agentforge-healthcare

# App Configuration
APP_ENV=development
LOG_LEVEL=INFO
